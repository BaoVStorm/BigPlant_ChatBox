{
  "name": "bigplant-chatbox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Node launcher for BigPlant local Python RAG chatbot",
  "scripts": {
    "doctor": "node scripts/node/doctor.mjs",
    "env:init": "node scripts/node/init-env.mjs",
    "deps": "node scripts/node/install-deps.mjs",
    "deps:cuda": "node scripts/node/install-deps.mjs --cuda",
    "model:download": "node model_downloader/download_qwen2_5_7b_gguf.mjs",
    "model:download:gwen": "node model_downloader/download_qwen2_5_7b_gguf.mjs",
    "model:download:llama": "node model_downloader/download_llama_3_1_8b_gguf.mjs",
    "model:download:vinallama": "node model_downloader/download_vinallama_7b_gguf.mjs",
    "embedding:download": "node model_downloader/download_bge_m3_embedding.mjs",
    "models:download": "npm run model:download:gwen && npm run embedding:download",
    "models:download:all": "npm run model:download:gwen && npm run model:download:llama && npm run model:download:vinallama && npm run embedding:download",
    "dev": "node scripts/node/run-api.mjs --reload",
    "start": "node scripts/node/run-api.mjs",
    "compile": "node scripts/node/run-python.mjs -m compileall app scripts",
    "ingest:products": "node scripts/node/run-python.mjs scripts/ingest_products.py",
    "ingest:knowledge": "node scripts/node/run-python.mjs scripts/ingest_knowledge.py",
    "eval:ai": "node scripts/node/run-python.mjs scripts/evaluate_ai_agent.py",
    "eval:ai:quick": "node scripts/node/run-python.mjs scripts/evaluate_ai_agent.py --skip-vector"
  },
  "engines": {
    "node": ">=20"
  }
}
