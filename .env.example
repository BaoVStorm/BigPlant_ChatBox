MONGO_URI=mongodb+srv://<username>:<password>@cluster0.flsvljh.mongodb.net/
MONGO_DB_NAME=bigplant

APP_HOST=0.0.0.0
APP_PORT=3015
SSH_REMOTE_HOST=<username>@<server_ip>

# Local LLM. Download a GGUF model and point this path to it.
# Recommended balanced model for RTX 4060 Ti 16GB: Qwen2.5-7B-Instruct Q4_K_M.
# Current default: ./models/qwen2.5-7b-instruct-q4_k_m-00001-of-00002.gguf
# Llama option: ./models/Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf
# Vietnamese-specialized option: ./models/vinallama-7b-chat_q5_0.gguf
LLM_MODEL_PATH=./models/qwen2.5-7b-instruct-q4_k_m-00001-of-00002.gguf
LLM_PROMPT_FORMAT=auto
LLM_USE_FOR_PRODUCT_INFO=false
LLM_USE_FOR_RECOMMENDATION=false
LLM_USE_FOR_RAG=false
LLM_CONTEXT_SIZE=4096
LLM_GPU_LAYERS=-1
LLM_MAX_TOKENS=768
LLM_TEMPERATURE=0.2

# Product prices in current seed data behave like USD-scale prices.
CATALOG_PRICE_CURRENCY=USD
VND_PER_USD=25000

PLANT_DETECT_API_URL=http://127.0.0.1:3104/api/plant_detect
PLANT_DETECT_TIMEOUT_SECONDS=20
PLANT_DETECT_TOPK=5
PLANT_DETECT_TWO_PASS=true
PLANT_DETECT_USE_MOCK=false

# Local embedding model for Vietnamese/multilingual semantic search.
# Can be BAAI/bge-m3 for auto-download, or ./models/embeddings/bge-m3 after npm run embedding:download.
EMBEDDING_MODEL_NAME=./models/embeddings/bge-m3
EMBEDDING_DEVICE=cuda

PRODUCT_VECTOR_INDEX=product_vector_index
KNOWLEDGE_VECTOR_INDEX=knowledge_vector_index
PRODUCT_EMBEDDING_FIELD=embedding
KNOWLEDGE_EMBEDDING_FIELD=embedding

PRODUCTS_COLLECTION=products
PRODUCT_CATEGORIES_COLLECTION=product_categories
PRODUCT_VARIANTS_COLLECTION=product_variants
PRODUCT_IMAGES_COLLECTION=product_images
VARIANT_INVENTORY_COLLECTION=variant_inventory
PLANTS_COLLECTION=plants
CHAT_SESSIONS_COLLECTION=chat_sessions
CHAT_MESSAGES_COLLECTION=chat_messages
KNOWLEDGE_ARTICLES_COLLECTION=plant_knowledge_articles
KNOWLEDGE_CHUNKS_COLLECTION=knowledge_chunks
